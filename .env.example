APP_NAME="PCVerse"
APP_URL=http://127.0.0.1:8080
APP_DEBUG=true
APP_VERSION=1.0.0

DB_DRIVER=sqlite
DB_SQLITE_PATH=storage/database/pcverse.sqlite

# GitHub releases — update banner checks drmikecrypto/pc-lab-kit by default
GITHUB_OWNER=drmikecrypto
GITHUB_REPO=pc-lab-kit
UPDATE_CHECK_TTL_SECONDS=21600

# Optional AI advisor — or set in the lab UI (Settings → AI advisor button)
# Use gpt-4o for strongest analysis; gpt-4o-mini is faster/cheaper
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT_SECONDS=120
